# ============================================================
#  StockWatch 配置文件
#  复制本文件为 .env，按说明填写，然后运行 bash start.sh
# ============================================================
#
#  【必填】最简配置：只需填这4项就能跑起来
#  ──────────────────────────────────────────
#  1. 你关注的股票（6位代码，逗号分隔，不加空格）
WATCHLIST=600519,000858,510300
#
#  2-4. AI 模型（三选一，详见下方各方案说明）
#  方案A：本地免费 Ollama（推荐，数据不出本机）
#    LLM_PROVIDER=openai
#    LLM_BASE_URL=http://127.0.0.1:11434/v1
#    LLM_MODEL=qwen2.5:7b
#    LLM_API_KEY=
#
#  方案B：DeepSeek API（低价，国内可用）
#    LLM_PROVIDER=openai
#    LLM_BASE_URL=https://api.deepseek.com/v1
#    LLM_MODEL=deepseek-chat
#    LLM_API_KEY=sk-xxxxxxxx   ← 去 platform.deepseek.com 申请
#
#  方案C：MiniMax（国内服务商）
#    LLM_PROVIDER=openai
#    LLM_BASE_URL=https://api.minimaxi.com/v1
#    LLM_MODEL=MiniMax-M2.7
#    LLM_API_KEY=              ← 去 minimaxi.com 申请
#  ──────────────────────────────────────────
#  填好上面4项后，其他配置用默认值即可。
#  通知会显示在 Web 控制台（浏览器 http://localhost:8765）。
# ============================================================


# ===== AI 模型配置 =====
# 取值：openai（兼容接口）| anthropic | minimax
LLM_PROVIDER=openai

# API Key（本地 Ollama 可留空；其他服务填对应平台的密钥）
LLM_API_KEY=

# 接口地址（选了哪个方案就填哪个地址，见上方说明）
LLM_BASE_URL=https://api.minimaxi.com/v1

# 模型名称（与接口地址对应）
LLM_MODEL=MiniMax-M2.7

# AI 回复详细程度：concise（简洁）| balanced（均衡）| detailed（详细）| expert（专家级）
AI_RESPONSE_STYLE=balanced


# ===== 通知渠道 =====
# web   → 只在本地浏览器查看（推荐先用这个，无需配飞书）
# feishu → 通过飞书/Lark 推送到手机（需要下方的飞书凭证）
NOTIFY_CHANNEL=web

# ---- 飞书配置（NOTIFY_CHANNEL=feishu 时才需要填）----
# 自建飞书应用的凭证，在飞书开放平台 → 我的应用 中创建
FEISHU_APP_ID=cli_xxxxxxxxxx
FEISHU_APP_SECRET=

# 接收消息的账号（用哪种方式就填对应值）
FEISHU_RECEIVE_ID=           # 填 open_id / user_id / email 之一
FEISHU_RECEIVE_ID_TYPE=open_id  # 取值：open_id | user_id | email | chat_id

# 可选：飞书事件订阅的验证 token 和加密 key（机器人接收消息时需要）
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=


# ===== 自选股上限 =====
# 每次分析最多处理多少只（含自动热门池，建议 30-50）
MAX_STOCKS_PER_RUN=50

# 置信度阈值：低于此值的分析不推送（0~1，越高越严格）
MIN_CONFIDENCE_TO_PUSH=0.6

# 默认止损比例（买入价的百分比，AI 未输出止损时自动填入）
STOP_LOSS_FALLBACK_PCT=0.07   # 0.07 = 跌7%触发止损


# ===== 提醒级别 =====
# 控制哪些提醒会推送给你：
#   critical = 必须看（跌破止损、重大利空等）
#   warning  = 建议看（BUY/SELL 信号、盯价触达）
#   info     = 普通提醒（仅记录，较安静）
# 建议普通用户只留 critical,warning，减少打扰
ALERT_LEVELS=critical,warning,info

# 安心模式：没有重大风险时，收盘后推送"今日不用盯盘"
ENABLE_REASSURANCE_MODE=false

# 家庭版一句话：用无术语的话告诉家人"今天要不要操作"
ENABLE_FAMILY_BRIEF=false

# 收盘后推送当天总结（15:00 后运行时生效）
ENABLE_AFTER_CLOSE_SUMMARY=false


# ===== Web 控制台访问保护 =====
# 默认只监听本机（127.0.0.1），不需要密码。
# 如果要用手机访问（局域网/公网），必须先设置此密码！
WEB_AUTH_TOKEN=


# ===== 日志 =====
LOG_LEVEL=INFO


# ===== 高级：v2 量化功能（默认关闭，需要额外训练步骤）=====
# 开启 Alpha158 因子（需要 pandas/numpy）
ENABLE_ALPHA158=false

# 开启 LightGBM 排序模型（需要先运行 scripts/train_lgbm.py）
ENABLE_LGBM=false
LGBM_MODEL_PATH=~/.stockwatch/models/lgbm.txt

# 开启置信度校准
ENABLE_CALIBRATION=false
CALIBRATION_LOOKBACK_DAYS=5
CALIBRATION_MIN_SAMPLES=50

# 开启市场波动率状态检测
ENABLE_REGIME=false

# 开启板块相对强弱分析
ENABLE_SECTOR=false


# ===== 兼容旧版配置（可忽略）=====
# 旧版 MINIMAX_* 配置仍兼容；如果同时有 LLM_*，优先用 LLM_*
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.7
