# ===== LLM =====
# 推荐使用通用 LLM_* 配置。OpenAI-compatible 可接 MiniMax、OpenAI、DeepSeek、
# 通义千问兼容接口、硅基流动、OpenRouter、Ollama/vLLM/LM Studio 等本地服务。
# LLM_PROVIDER 取值：openai | openai-compatible | anthropic | custom | local | minimax
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=https://api.minimaxi.com/v1
LLM_MODEL=MiniMax-M2.7
# AI 回复风格：concise | balanced | detailed | expert
AI_RESPONSE_STYLE=balanced

# Anthropic 示例：
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-xxxxxxxx
# LLM_MODEL=claude-3-5-sonnet-latest

# 本地 OpenAI-compatible 示例（通常可留空 API Key）：
# LLM_PROVIDER=openai
# LLM_BASE_URL=http://127.0.0.1:11434/v1
# LLM_MODEL=qwen2.5:7b
# LLM_API_KEY=

# 旧版 MiniMax 配置仍兼容；如果设置了 LLM_*，优先使用 LLM_*。
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.7

# ===== 飞书自建应用 =====
# 通知渠道：feishu | web。web 表示只在本地 Web 控制台查看，不要求飞书凭证。
NOTIFY_CHANNEL=feishu
FEISHU_APP_ID=cli_xxxxxxxxxx
FEISHU_APP_SECRET=
FEISHU_RECEIVE_ID=                 # open_id / user_id / email 之一
FEISHU_RECEIVE_ID_TYPE=open_id     # 取值：open_id | user_id | email
FEISHU_VERIFICATION_TOKEN=         # 可选，飞书事件订阅 verification token
FEISHU_ENCRYPT_KEY=                # 可选，飞书事件订阅 encrypt key

# ===== 数据源 =====
TUSHARE_TOKEN=                     # 可选,留空则全用 AKShare

# ===== 业务参数 =====
WATCHLIST=600449,600900,601398,600089,001298,520570,513010,513130
MAX_STOCKS_PER_RUN=50
MIN_CONFIDENCE_TO_PUSH=0.6
STOP_LOSS_FALLBACK_PCT=0.07

# ===== 少盯盘提醒体验 =====
# critical=必须看, warning=建议看, info=仅记录/普通提醒
# 例如只看红橙提醒: ALERT_LEVELS=critical,warning
ALERT_LEVELS=critical,warning,info
ENABLE_REASSURANCE_MODE=false
ENABLE_FAMILY_BRIEF=false
ENABLE_AFTER_CLOSE_SUMMARY=false

# ===== 运行 =====
LOG_LEVEL=INFO

# ===== v2 新增（默认关闭） =====
ENABLE_CALIBRATION=false
CALIBRATION_LOOKBACK_DAYS=5
CALIBRATION_MIN_SAMPLES=50

ENABLE_ALPHA158=false

ENABLE_LGBM=false
LGBM_MODEL_PATH=~/.stockwatch/models/lgbm.txt

ENABLE_REGIME=false

ENABLE_SECTOR=false
