# ===== LLM =====
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.7

# ===== 飞书自建应用 =====
FEISHU_APP_ID=cli_xxxxxxxxxx
FEISHU_APP_SECRET=
FEISHU_RECEIVE_ID=                 # open_id / user_id / email 之一
FEISHU_RECEIVE_ID_TYPE=open_id     # 取值：open_id | user_id | email

# ===== 数据源 =====
TUSHARE_TOKEN=                     # 可选,留空则全用 AKShare

# ===== 业务参数 =====
WATCHLIST=600519,000858,510300,510500,159915
MAX_STOCKS_PER_RUN=50
MIN_CONFIDENCE_TO_PUSH=0.6
STOP_LOSS_FALLBACK_PCT=0.07

# ===== 运行 =====
LOG_LEVEL=INFO

# ===== v2 新增（默认关闭） =====
ENABLE_CALIBRATION=false
CALIBRATION_LOOKBACK_DAYS=5
CALIBRATION_MIN_SAMPLES=50

ENABLE_ALPHA158=false

ENABLE_LGBM=false
LGBM_MODEL_PATH=~/.stockwatch/models/lgbm.txt

ENABLE_REGIME=false

ENABLE_SECTOR=false
